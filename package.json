{
  "name": "architect-ai",
  "version": "2.1.0",
  "description": "Runtime de Regras Comportamentais — valida e bloqueia código inseguro, sem teste e fora de padrão gerado por IA",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "bin": {
    "architect": "bin/architect.js"
  },
  "keywords": [
    "ai-agent",
    "security",
    "lint",
    "tdd",
    "code-quality",
    "behavior-engine"
  ],
  "author": "Nando Dev <nandinhos@gmail.com>",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "jest": "^30.3.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
